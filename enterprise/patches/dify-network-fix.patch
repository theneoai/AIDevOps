From 786324e64a2d21b20cf27c7d789a7ac60712c136 Mon Sep 17 00:00:00 2001
From: Bot-lucas-hsueh <lucas_hsueh_bot@outlook.com>
Date: Thu, 23 Apr 2026 23:17:40 +0800
Subject: [PATCH 2/2] network: add dify-network to nginx service

Enables nginx to reach web service on dify-network IP where
Next.js is listening, fixing 502 errors for /apps and other routes.
---
 docker/docker-compose.yaml | 3 +++
 1 file changed, 3 insertions(+)

diff --git a/docker/docker-compose.yaml b/docker/docker-compose.yaml
index 736a669..6c819f7 100644
--- a/docker/docker-compose.yaml
+++ b/docker/docker-compose.yaml
@@ -1182,6 +1182,9 @@ services:
     ports:
       - "${EXPOSE_NGINX_PORT:-80}:${NGINX_PORT:-80}"
       - "${EXPOSE_NGINX_SSL_PORT:-443}:${NGINX_SSL_PORT:-443}"
+    networks:
+      - default
+      - dify-network
 
   # The Weaviate vector store.
   weaviate:
-- 
