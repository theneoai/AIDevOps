# ─── 通用配置 ───
# 日志级别: debug, info, warn, error
LOG_LEVEL=info
# 运行环境: development, production, test
NODE_ENV=production

# ─── Tool Service 配置 ───
# 服务端口 (默认 3000，映射到宿主机 3100)
SERVICE_PORT=3000

# ─── MCP Server 通用配置 ───
# MCP Server 端口 (默认 3000，每个服务映射到不同宿主机端口)
MCP_SERVER_PORT=3000
# MCP SSE 端点路径
MCP_SERVER_PATH=/sse

# ─── Dify API 适配器（推荐，默认启用）───
# Dify REST API 基础地址（例如 http://localhost/v1）
DIFY_BASE_URL=http://localhost/v1
# Dify API Key（从 Dify 控制台"设置 → API 密钥"获取）
DIFY_API_KEY=your-dify-api-key

# ─── Dify DB 适配器（已弃用，仅兜底）───
# 仅在 dify.adapter=db 时需要，将在 v0.4.0 移除
DIFY_DB_HOST=localhost
DIFY_DB_PORT=5432
DIFY_DB_USER=postgres
DIFY_DB_PASSWORD=difyai123456
DIFY_DB_NAME=dify

# ─── MCP: 微信公众号 ───
# 微信公众号 AppID，从微信公众平台获取
WECHAT_APP_ID=your-wechat-app-id
# 生产环境请使用 Docker Secrets（/run/secrets/wechat_app_secret），仅开发环境使用此变量
WECHAT_APP_SECRET=your-wechat-app-secret

# ─── P1: 可观测性 ───
# Langfuse 自托管密钥（make observability-up 后在 http://localhost:3002 配置）
LANGFUSE_SECRET=changeme-replace-in-production
LANGFUSE_SALT=changeme-replace-in-production
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=http://langfuse-server:3000
# OTel 导出端点（默认指向 Langfuse）
OTEL_EXPORTER_OTLP_ENDPOINT=http://langfuse-server:3000/api/public/otel/v1/traces
OTEL_ENABLED=true
# Grafana 管理员账户
GRAFANA_USER=admin
GRAFANA_PASSWORD=changeme
# 告警 Webhook
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook/url

# ─── P2: 安全合规 ───
# JWT 密钥（用于 RBAC token 签发/验证）
JWT_SECRET=changeme-use-a-strong-random-secret-in-production
# Presidio PII 检测服务（make security-up 后自动可用）
PRESIDIO_ANALYZER_URL=http://presidio-analyzer:3000
PRESIDIO_ANONYMIZER_URL=http://presidio-anonymizer:3000
PRESIDIO_ENABLED=true
# Guardrails AI Token（可选）
GUARDRAILS_TOKEN=
# 审计日志数据库（独立于 Dify DB）
AUDIT_DB_HOST=localhost
AUDIT_DB_PORT=5432
AUDIT_DB_USER=postgres
AUDIT_DB_PASSWORD=changeme
AUDIT_DB_NAME=enterprise

# ─── P5: 生态系统 ───
# MCP: 飞书 (Lark)
# 飞书开放平台 AppID，从 https://open.feishu.cn 获取
FEISHU_APP_ID=your-feishu-app-id
# 生产环境请使用 Docker Secrets（/run/secrets/feishu_app_secret），仅开发环境使用此变量
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_BASE_URL=https://open.feishu.cn

# MCP: 钉钉
# 钉钉开放平台 AppKey，从 https://open.dingtalk.com 获取
DINGTALK_APP_KEY=your-dingtalk-app-key
# 生产环境请使用 Docker Secrets（/run/secrets/dingtalk_app_secret），仅开发环境使用此变量
DINGTALK_APP_SECRET=your-dingtalk-app-secret
DINGTALK_BASE_URL=https://oapi.dingtalk.com

# P5-1: 多后端支持
# 切换后端: dify | langflow
BACKEND_TYPE=dify
# Langflow 后端（当 BACKEND_TYPE=langflow 时需要）
LANGFLOW_BASE_URL=http://localhost:7860
LANGFLOW_API_KEY=
